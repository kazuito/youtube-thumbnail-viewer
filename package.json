    "typecheck": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.6",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "wxt": "^0.20.11"
  }
}
