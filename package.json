{
  "name": "youtube-thumbnail-viewer",
  "private": true,
  "version": "0.0.5",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
